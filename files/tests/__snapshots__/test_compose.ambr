# name: test_files[compose.proxy.yml][1_compose.proxy.data.yml]
  '''
  x-logging: &id001
    driver: wc-test-driver
    options:
      mode: non-blocking
  services:
    limbo:
      depends_on:
      - loki
      logging: *id001
      labels:
      - traefik.enable=true
      - traefik.http.routers.limbo-wc-test~test.rule=Host(`test.localhost`)
      - traefik.http.routers.limbo-wc-test~test.middlewares=limbo-wc-test~test+location
      - traefik.http.routers.limbo-wc-test~test.service=noop@internal
      - traefik.http.middlewares.limbo-wc-test~test+location.redirectregex.regex=^.+$
      - traefik.http.middlewares.limbo-wc-test~test+location.redirectregex.replacement=https://example.com/
      - traefik.http.routers.limbo-wc-test~duck.rule=Host(`duck.localhost`)
      - traefik.http.routers.limbo-wc-test~duck.middlewares=limbo-wc-test~duck+location
      - traefik.http.routers.limbo-wc-test~duck.service=noop@internal
      - traefik.http.middlewares.limbo-wc-test~duck+location.redirectregex.regex=^.+$
      - traefik.http.middlewares.limbo-wc-test~duck+location.redirectregex.replacement=https://duckduckgo.com/
  
  '''
# ---
# name: test_files[compose.proxy.yml][1_compose.proxy.yml]
  '''
  services:
    limbo:
      x-web-conductor:
        routes:
          test:
            host: test.localhost
            location: https://example.com/
