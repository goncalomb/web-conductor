# name: test_files[compose.proxy.yml][0_compose.proxy.data.yml]
  '''
  x-logging: &id001
    driver: wc-test-driver
    options:
      mode: non-blocking
  services:
    traefik:
      depends_on:
      - loki
      logging: *id001
      labels:
      - traefik.enable=true
      - traefik.http.routers.traefik-wc-test.service=api@internal
      - traefik.http.routers.traefik-wc-test.rule=Host(`wc.localhost`) && (Path(`/traefik`)
        || PathPrefix(`/traefik/`))
      - traefik.http.routers.traefik-wc-test.middlewares=internal@file,auth@file
      - homepage.group=Core Test
      - homepage.icon=traefik.png
      - homepage.name=Traefik
      - homepage.description=Traefik 123
      - homepage.href=https://wc.localhost/traefik
    limbo:
      depends_on:
      - loki
      logging: *id001
      labels:
      - traefik.enable=true
      - traefik.http.services.limbo-wc-test.loadbalancer.server.port=80
      - traefik.http.routers.limbo-wc-test.rule=PathPrefix(`/`)
      - traefik.http.routers.limbo-wc-test.priority=1
      - homepage.group=Core Test
      - homepage.icon=mdi-server-outline
      - homepage.name=Limbo
      - homepage.description=Limbo 123
  
  '''
